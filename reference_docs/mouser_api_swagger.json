{
  "swagger": "2.0",
  "info": {
    "version": "V1",
    "title": "Mouser APIs",
    "description": "With Mouser's APIs, you can get quick and reliable access to product data as well as cart and ordering capabilities.",
    "x-swagger-net-version": "8.5.12.001"
  },
  "host": "api.mouser.com",
  "schemes": [
