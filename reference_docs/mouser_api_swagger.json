  "paths": {
    "/api/v{version}/search/partnumber": {
      "post": {
        "tags": [
          "SearchApi"
        ],
        "summary": "Search parts by part number and return a maximum of 50 parts. Please review the SearchByPartRequest item in the Models section below to view the detailed description of request parameters.",
        "operationId": "SearchApi_SearchByPartNumber",
        "consumes": [
          "application/json",
          "text/json",
          "application/xml",
          "text/xml",
          "application/x-www-form-urlencoded"
        ],
        "produces": [
          "application/json",
          "text/json",
          "application/xml",
          "text/xml"
        ],
        "parameters": [
          {
            "name": "request",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SearchByPartRequestRoot"
            }
          },
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "type": "string"
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/SearchResponseRoot"
            }
          }
        }
      }
    }
  },
  "definitions": {
